{
  "name": "workflow-debug-this",
  "layer": "workflow",
  "layer_badge": "Workflow",
  "default_program": "[stages: preflight>detect>analyze>implement>verify>review>audit | scope: repo|diff|paths(glob,...) | policy: evidence,quality-gates{tests},deterministic-output | lens: feynman | output: md(contract=v1)]",
  "required_inputs": [
    {
      "name": "TARGET_SCOPE",
      "type": "path|module|repo",
      "required": true,
      "description": "Scope where the failure occurs."
    },
    {
      "name": "FAILURE_SYMPTOM",
      "type": "string",
      "required": true,
      "description": "Observed failure symptom."
    },
    {
      "name": "EXPECTED_BEHAVIOR",
      "type": "string",
      "required": true,
      "description": "Expected behavior."
    }
  ],
  "display_name": "Workflow / Debug This",
  "browse_category": "debug",
  "browse_priority": 10,
  "is_category_default": true,
  "codex_surface": "public_entry",
  "starter_inputs": [
    {
      "key": "SCOPE",
      "label": "어디서 문제가 나는지",
      "required": true,
      "maps_to": [
        "TARGET_SCOPE"
      ],
      "derive_from_raw_request": true
    },
    {
      "key": "QUESTION",
      "label": "관찰된 문제",
      "required": true,
      "maps_to": [
        "FAILURE_SYMPTOM"
      ],
      "help": "원인 추측이 아니라 관찰된 실패를 적는다."
    },
    {
      "key": "EXPECTED",
      "label": "기대 동작",
      "required": true,
      "maps_to": [
        "EXPECTED_BEHAVIOR"
      ]
    }
  ],
  "expands_to": [
    "$debug-capture-failure",
    "$debug-map-impact",
    "$debug-find-root-cause",
    "$test-find-gaps"
  ]
}
