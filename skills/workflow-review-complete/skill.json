{
  "name": "workflow-review-complete",
  "layer": "workflow",
  "layer_badge": "Workflow",
  "default_program": "[stages: preflight>detect>analyze>review>handoff>audit | scope: repo|diff|paths(glob,...) | policy: evidence,quality-gates{tests,security},deterministic-output | lens: kahneman-tversky | output: md(contract=v1)]",
  "required_inputs": [
    {
      "name": "TARGET_SCOPE",
      "type": "path|module|diff|repo",
      "required": true,
      "description": "Code to review."
    },
    {
      "name": "CHANGE_INTENT",
      "type": "string",
      "required": true,
      "description": "Claimed purpose of the change."
    },
    {
      "name": "REVIEW_DEPTH",
      "type": "full|security-focus|quality-focus",
      "required": false,
      "allowed_values": ["full", "security-focus", "quality-focus"],
      "description": "Which dimensions to emphasize. Defaults to full."
    }
  ],
  "display_name": "Workflow / Review Complete",
  "browse_category": "workflow",
  "browse_priority": 56,
  "is_category_default": false,
  "codex_surface": "expert",
  "expands_to": ["analyze-structure", "review-quality", "review-security", "review-failure-paths", "review-change"],
  "outputs": [
    {
      "name": "FINAL_VERDICT",
      "required": true,
      "allowed_values": ["integrate", "hold"],
      "description": "Synthesized integrate/hold decision."
    }
  ],
  "starter_inputs": [
    {
      "key": "SCOPE",
      "label": "리뷰할 코드 범위",
      "required": true,
      "maps_to": ["TARGET_SCOPE"],
      "derive_from_raw_request": true
    },
    {
      "key": "CHANGE",
      "label": "변경 목적 한 줄 설명",
      "required": true,
      "maps_to": ["CHANGE_INTENT"],
      "derive_from_raw_request": true
    },
    {
      "key": "DEPTH",
      "label": "리뷰 깊이 (full/security-focus/quality-focus)",
      "required": false,
      "maps_to": ["REVIEW_DEPTH"]
    }
  ]
}
