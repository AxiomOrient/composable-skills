{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConsensusAgentResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "proposal",
    "must_keep",
    "must_avoid",
    "assumptions",
    "uncertainties",
    "next_checks",
    "confidence"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "proposal": {
      "type": "string",
      "minLength": 1
    },
    "must_keep": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "must_avoid": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "$defs": {
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement",
        "why",
        "support",
        "confidence"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "why": {
          "type": "string",
          "minLength": 1
        },
        "support": {
          "type": "string",
          "enum": [
            "grounded",
            "reasoned",
            "speculative"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
