{
  "name": "workflow-analyze-codebase",
  "layer": "workflow",
  "layer_badge": "Workflow",
  "default_program": "[stages: preflight>detect>analyze>review>handoff>audit | scope: repo|diff|paths(glob,...) | policy: evidence,quality-gates{docs},deterministic-output | lens: hickey-carmack | output: md(contract=v1)]",
  "required_inputs": [
    {
      "name": "TARGET_SCOPE",
      "type": "path|module|repo",
      "required": true,
      "description": "Codebase or module to analyze."
    },
    {
      "name": "ANALYSIS_GOAL",
      "type": "structure|complexity|dependencies|full",
      "required": false,
      "allowed_values": ["structure", "complexity", "dependencies", "full"],
      "description": "Primary analytical objective. Defaults to full."
    },
    {
      "name": "KNOWN_CONCERNS",
      "type": "list",
      "required": false,
      "shape": "{CONCERN}",
      "description": "Known problem areas or questions to focus on."
    }
  ],
  "display_name": "Workflow / Analyze Codebase",
  "browse_category": "workflow",
  "browse_priority": 55,
  "is_category_default": false,
  "codex_surface": "expert",
  "expands_to": ["analyze-structure", "analyze-complexity", "analyze-dependencies"],
  "starter_inputs": [
    {
      "key": "SCOPE",
      "label": "분석할 코드베이스나 모듈",
      "required": true,
      "maps_to": ["TARGET_SCOPE"],
      "derive_from_raw_request": true
    },
    {
      "key": "GOAL",
      "label": "분석 목표 (structure/complexity/dependencies/full)",
      "required": false,
      "maps_to": ["ANALYSIS_GOAL"],
      "derive_from_raw_request": true
    },
    {
      "key": "CONCERNS",
      "label": "이미 알고 있는 문제 영역",
      "required": false,
      "maps_to": ["KNOWN_CONCERNS"]
    }
  ]
}
