{
  "name": "doc-find-all",
  "layer": "atomic",
  "layer_badge": "Atomic",
  "response_profile": "documentation_report",
  "default_program": "[stages: preflight>detect>analyze>review>handoff>audit | scope: repo|diff|paths(glob,...) | policy: evidence,quality-gates{docs},deterministic-output | lens: nielsen-norman | output: md(contract=v1)]",
  "required_inputs": [
    {
      "name": "TARGET_SCOPE",
      "type": "path|docs-folder|repo",
      "required": true,
      "description": "Documentation scope to inventory."
    },
    {
      "name": "INVENTORY_GOAL",
      "type": "cleanup|navigation|coverage|mixed",
      "required": false,
      "description": "Why the inventory is being created. Defaults to `mixed` when omitted."
    }
  ],
  "display_name": "Doc / Find All",
  "browse_category": "doc",
  "browse_priority": 50,
  "is_category_default": false,
  "codex_surface": "expert",
  "starter_inputs": [
    {
      "key": "SCOPE",
      "label": "문서 스캔 범위",
      "required": true,
      "maps_to": [
        "TARGET_SCOPE"
      ],
      "derive_from_raw_request": true
    },
    {
      "key": "GOAL",
      "label": "스캔 목적",
      "required": false,
      "maps_to": [
        "INVENTORY_GOAL"
      ],
      "derive_from_raw_request": true
    }
  ]
}
