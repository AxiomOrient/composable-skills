{
  "name": "scout-structure-map",
  "layer": "atomic",
  "layer_badge": "Atomic",
  "response_profile": "analysis_report",
  "default_program": "[stages: preflight>detect>analyze>review>handoff>audit | scope: repo|diff|paths(glob,...) | policy: evidence,quality-gates{docs},deterministic-output | lens: hickey-carmack | output: md(contract=v1)]",
  "required_inputs": [
    {
      "name": "TARGET_SCOPE",
      "type": "file|module|folder|repo|artifact",
      "required": true,
      "description": "Bounded scope to map."
    },
    {
      "name": "STRUCTURE_QUESTION",
      "type": "string",
      "required": false,
      "description": "Exact structure uncertainty to resolve. Default to the main current-state structure question when omitted."
    },
    {
      "name": "MAP_FOCUS",
      "type": "boundaries|responsibilities|interactions|mixed",
      "required": false,
      "allowed_values": [
        "boundaries",
        "responsibilities",
        "interactions",
        "mixed"
      ],
      "description": "Primary structure lens for the map."
    },
    {
      "name": "KNOWN_EVIDENCE",
      "type": "list",
      "required": false,
      "shape": "{TYPE, REF, WHY_RELEVANT}",
      "description": "Files, docs, traces, or notes already known."
    },
    {
      "name": "CONSTRAINTS",
      "type": "list",
      "required": false,
      "shape": "{CONSTRAINT}",
      "description": "Scope or interpretation limits."
    }
  ],
  "display_name": "Scout / Structure Map",
  "browse_category": "scout",
  "browse_priority": 50,
  "is_category_default": false,
  "codex_surface": "expert",
  "starter_inputs": [
    {
      "key": "SCOPE",
      "label": "어디를 구조적으로 볼지",
      "required": true,
      "maps_to": [
        "TARGET_SCOPE"
      ],
      "derive_from_raw_request": true
    },
    {
      "key": "QUESTION",
      "label": "무슨 구조 질문을 풀지",
      "required": false,
      "maps_to": [
        "STRUCTURE_QUESTION"
      ]
    },
    {
      "key": "GOAL",
      "label": "어떤 관점으로 구조를 볼지",
      "required": false,
      "maps_to": [
        "MAP_FOCUS"
      ],
      "derive_from_raw_request": true
    },
    {
      "key": "EVIDENCE",
      "label": "이미 가진 근거",
      "required": false,
      "maps_to": [
        "KNOWN_EVIDENCE"
      ]
    },
    {
      "key": "CONSTRAINTS",
      "label": "지켜야 할 제약",
      "required": false,
      "maps_to": [
        "CONSTRAINTS"
      ],
      "derive_from_raw_request": true
    }
  ]
}
