{
  "name": "scout-option-compare",
  "layer": "atomic",
  "layer_badge": "Atomic",
  "default_program": "[stages: preflight>detect>analyze>review>handoff>audit | scope: repo|diff|paths(glob,...) | policy: evidence,quality-gates{docs},deterministic-output | lens: kahneman-tversky | output: md(contract=v1)]",
  "required_inputs": [
    {
      "name": "TARGET_SCOPE",
      "type": "file|module|folder|repo|artifact",
      "required": true,
      "description": "Bounded scope the decision applies to."
    },
    {
      "name": "DECISION_QUESTION",
      "type": "string",
      "required": true,
      "description": "Exact choice to resolve."
    },
    {
      "name": "OPTION_SET",
      "type": "list",
      "required": true,
      "shape": "{OPTION, DESCRIPTION}",
      "description": "Explicit options to compare."
    },
    {
      "name": "KNOWN_EVIDENCE",
      "type": "list",
      "required": false,
      "shape": "{TYPE, REF, WHY_RELEVANT}",
      "description": "Files, docs, measurements, or prior notes already known."
    },
    {
      "name": "CONSTRAINTS",
      "type": "list",
      "required": false,
      "shape": "{CONSTRAINT}",
      "description": "Decision constraints or non-goals."
    }
  ],
  "display_name": "Scout / Option Compare",
  "browse_category": "scout",
  "browse_priority": 50,
  "is_category_default": false,
  "codex_surface": "expert",
  "starter_inputs": [
    {
      "key": "SCOPE",
      "label": "어디를 기준으로 비교할지",
      "required": true,
      "maps_to": [
        "TARGET_SCOPE"
      ],
      "derive_from_raw_request": true
    },
    {
      "key": "QUESTION",
      "label": "무슨 선택을 해야 하는지",
      "required": true,
      "maps_to": [
        "DECISION_QUESTION"
      ]
    },
    {
      "key": "EVIDENCE",
      "label": "이미 가진 근거",
      "required": false,
      "maps_to": [
        "KNOWN_EVIDENCE"
      ]
    },
    {
      "key": "CONSTRAINTS",
      "label": "지켜야 할 제약",
      "required": false,
      "maps_to": [
        "CONSTRAINTS"
      ],
      "derive_from_raw_request": true
    }
  ]
}
