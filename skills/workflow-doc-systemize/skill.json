{
  "name": "workflow-doc-systemize",
  "layer": "workflow",
  "layer_badge": "Workflow",
  "default_program": "[stages: preflight>detect>analyze>plan>review>handoff>audit |\n scope: repo|diff|paths(glob,...) |\n policy: evidence,quality-gates{docs,compat},deterministic-output |\n lens: nielsen-norman |\n output: md(contract=v1)]",
  "required_inputs": [
    {
      "name": "TARGET_SCOPE",
      "type": "path|docs-folder|repo|subtree",
      "required": true,
      "description": "Documentation scope to systemize."
    },
    {
      "name": "CURATION_GOAL",
      "type": "lifecycle-governance|cleanup|surface-sync|mixed",
      "required": true,
      "description": "Why the docs surface is being cleaned or governed."
    },
    {
      "name": "AUDIENCE",
      "type": "general|developer|operator|maintainer|mixed",
      "required": true,
      "description": "Primary reader of the maintained docs surface."
    },
    {
      "name": "CONSTRAINTS",
      "type": "list",
      "required": false,
      "shape": "{CONSTRAINT}",
      "description": "Documentation constraints, non-goals, or protected surfaces."
    }
  ],
  "display_name": "Workflow / Doc Systemize",
  "browse_category": "doc",
  "browse_priority": 10,
  "is_category_default": true,
  "codex_surface": "public_entry",
  "starter_inputs": [
    {
      "key": "GOAL",
      "label": "문서 거버넌스 목표",
      "required": true,
      "maps_to": [
        "CURATION_GOAL"
      ],
      "derive_from_raw_request": true
    },
    {
      "key": "SCOPE",
      "label": "문서 범위",
      "required": true,
      "maps_to": [
        "TARGET_SCOPE"
      ],
      "derive_from_raw_request": true
    },
    {
      "key": "CONTEXT",
      "label": "유지할 문서의 주요 독자",
      "required": true,
      "maps_to": [
        "AUDIENCE"
      ],
      "derive_from_raw_request": true
    },
    {
      "key": "CONSTRAINTS",
      "label": "문서 제약",
      "required": false,
      "maps_to": [
        "CONSTRAINTS"
      ],
      "derive_from_raw_request": true
    }
  ],
  "expands_to": [
    "$doc-find-all",
    "$doc-curate",
    "$doc-write"
  ]
}
