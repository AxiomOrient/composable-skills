    { "key": "SCOPE", "label": "분석할 경계 (파일, 모듈, API)", "required": true, "maps_to": ["TARGET_SCOPE"], "derive_from_raw_request": true },
    { "key": "BOUNDARY_KIND", "label": "경계 종류 (module/api/service/layer)", "required": true, "maps_to": ["BOUNDARY_KIND"], "derive_from_raw_request": true },
    { "key": "DEPTH", "label": "분석 깊이 (surface/full)", "required": false, "maps_to": ["ANALYSIS_DEPTH"] }
  ]
}
