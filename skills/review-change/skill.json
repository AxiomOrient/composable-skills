{
  "name": "review-change",
  "layer": "atomic",
  "layer_badge": "Atomic",
  "default_program": "[stages: preflight>detect>analyze>review>handoff>audit |\n scope: diff|repo|paths(glob,...) |\n policy: evidence,quality-gates{tests,security,compat,style},deterministic-output |\n lens: kahneman-tversky |\n output: md(contract=v1)]",
  "required_inputs": [
    {
      "name": "REVIEW_GOAL",
      "type": "general-verdict|regression-risk|change-intent-check|narrow-focus",
      "required": true,
      "allowed_values": ["general-verdict", "regression-risk", "change-intent-check", "narrow-focus"],
      "description": "Type of review verdict needed."
    },
    {
      "name": "TARGET_SCOPE",
      "type": "diff|file|module|folder|repo",
      "required": true,
      "description": "Scope to review."
    },
    {
      "name": "CHANGE_INTENT",
      "type": "string",
      "required": true,
      "description": "Claimed purpose of the change."
    },
    {
      "name": "KNOWN_TEST_SIGNAL",
      "type": "list",
      "required": false,
      "shape": "{SIGNAL, STATUS, SOURCE}",
      "description": "Executed tests, missing tests, or known verification state."
    },
    {
      "name": "CONSTRAINTS",
      "type": "list",
      "required": false,
      "shape": "{CONSTRAINT}",
      "description": "Security-only, perf-only, compat-only, or other focus constraints."
    }
  ],
  "display_name": "Review / Change",
  "browse_category": "review",
  "browse_priority": 20,
  "is_category_default": false,
  "codex_surface": "expert",
  "starter_inputs": [
    {
      "key": "GOAL",
      "label": "리뷰 목적",
      "required": true,
      "maps_to": ["REVIEW_GOAL"],
      "derive_from_raw_request": true
    },
    {
      "key": "SCOPE",
      "label": "리뷰 범위",
      "required": true,
      "maps_to": ["TARGET_SCOPE"],
      "derive_from_raw_request": true
    },
    {
      "key": "CHANGE",
      "label": "변경 의도",
      "required": true,
      "maps_to": ["CHANGE_INTENT"],
      "derive_from_raw_request": true
    },
    {
      "key": "EVIDENCE",
      "label": "이미 있는 테스트 근거",
      "required": false,
      "maps_to": ["KNOWN_TEST_SIGNAL"]
    }
  ],
  "outputs": [
    {
      "name": "VERDICT",
      "required": true,
      "allowed_values": ["integrate", "hold"],
      "description": "Integrate or hold verdict with rationale."
    }
  ]
}
